{
  "name": "asset-pulse",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "dotenv -e apps/web/.env -- pnpm --filter @asset-pulse/db db:generate",
    "db:migrate": "dotenv -e apps/web/.env -- pnpm --filter @asset-pulse/db db:migrate",
    "db:push": "dotenv -e apps/web/.env -- pnpm --filter @asset-pulse/db db:push",
    "db:seed": "dotenv -e apps/web/.env -- pnpm --filter @asset-pulse/db db:seed"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1",
    "date-fns": "^4.4.0"
  }
}
